# Copy to .env and fill in. .env is gitignored — never commit a real key.
FIRECRAWL_API_KEY=fc-...

# Optional overrides
# FIRECRAWL_API_BASE=https://api.firecrawl.dev

# Optional AI — sharper query expansion + entity probes, and semantic ranking.
# ALL opt-in: with none set, the pipeline runs a full lexical path. Pick ONE provider.
#
# A) Hosted (no local setup):
# ANTHROPIC_API_KEY=sk-ant-...        # Claude — expansion + entity probes (no embeddings)
# ANTHROPIC_MODEL=claude-haiku-4-5
# OPENAI_API_KEY=sk-...               # OpenAI — expansion + entity probes + embeddings
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
#
# B) Local via Ollama (run `make models` to install + pull):
# OLLAMA_HOST=http://localhost:11434
# EMBED_MODEL=nomic-embed-text        # semantic dedup/rerank/diversity
# EXPAND_MODEL=llama3.2:3b            # expansion + entity probes
#
# Force a provider when several are set (else: anthropic > openai > ollama):
# LLM_PROVIDER=anthropic

# Hard-disable AI regardless of the above (e.g. a deploy whose box can't serve
# models). The UI AI toggle is greyed out with a tooltip; the server ignores any
# request to use models. Leave unset for local dev.
# AI_DISABLED=1
