# Copy to .env and fill in. .env is gitignored — never commit a real key.
FIRECRAWL_API_KEY=fc-...

# Optional overrides
# FIRECRAWL_API_BASE=https://api.firecrawl.dev
# PORT=8787

# Demo credentials for the authenticated-flow demo (injected via Playwright fill(),
# never sent to Firecrawl as a natural-language prompt). Safe to use the public
# the-internet.herokuapp.com test creds below.
DEMO_USERNAME=tomsmith
DEMO_PASSWORD=SuperSecretPassword!
