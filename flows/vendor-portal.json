{
  "name": "vendor-portal",
  "description": "Log into a vendor portal and reach a table that only renders after setup. Uses the public the-internet.herokuapp.com sandbox as a stand-in for a real authenticated dashboard (feedback #7 + #11).",
  "steps": [
    { "type": "goto", "url": "https://the-internet.herokuapp.com/login", "label": "Open the portal login" },
    { "type": "fill", "selector": "#username", "value": { "secret": "DEMO_USERNAME" }, "label": "Enter username (from secret)" },
    { "type": "fill", "selector": "#password", "value": { "secret": "DEMO_PASSWORD" }, "label": "Enter password (from secret)" },
    { "type": "click", "selector": "button[type=\"submit\"]", "label": "Submit login" },
    { "type": "expect", "selector": ".flash.success", "meaning": "auth", "label": "Confirm we are authenticated" },
    { "type": "goto", "url": "https://the-internet.herokuapp.com/dynamic_loading/2", "label": "Open the report that loads on demand" },
    { "type": "click", "selector": "#start button", "label": "Trigger the report build" },
    { "type": "waitFor", "selector": "#finish h4", "timeoutMs": 12000, "label": "Wait for the report to finish rendering" },
    { "type": "expect", "selector": "#finish h4", "label": "Confirm the report content exists" }
  ]
}
