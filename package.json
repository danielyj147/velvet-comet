{
  "name": "tracewright",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Step-level observability for Firecrawl browser flows: which step failed, why, and what the page looked like.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 8788",
    "build": "next build",
    "start": "next start -p 8788",
    "checkpoint": "tsx tracewright/checkpoint.ts",
    "flow:demo": "tsx tracewright/demo.ts",
    "search:demo": "tsx searchtrace/demo.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slider": "^1.4.1",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.4.7",
    "lucide-react": "^1.21.0",
    "next": "^15.5.19",
    "playwright-core": "^1.49.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "postcss": "^8.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
